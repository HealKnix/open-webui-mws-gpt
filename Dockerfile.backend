# Backend Development Dockerfile
# Python 3.11 with uvicorn for hot reload

FROM python:3.11-slim-bookworm

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy backend requirements
COPY backend/requirements.txt /app/backend/requirements.txt

# Install Python dependencies
RUN pip install --no-cache-dir uv && \
    uv pip install --system -r /app/backend/requirements.txt

# Copy backend source code
COPY backend /app/backend

# Copy static files for serving
COPY static /app/static

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PORT=8080
ENV OLLAMA_BASE_URL=http://host.docker.internal:11434
ENV CORS_ALLOW_ORIGIN=http://localhost:5173

# Expose FastAPI port
EXPOSE 8080

# Default command (will be overridden by compose)
CMD ["sh", "backend/dev.sh"]